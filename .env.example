APP_ENV=local
LOG_LEVEL=DEBUG
# text for local (human-readable), json in cloud (Cloud Logging auto-parses severity etc.)
LOG_FORMAT=text

SECRET_KEY = "jwt-demo-secret-key-change-me"

# App uses asyncmy (async); Alembic uses pymysql (sync).
# Locally WRITE/READ point at the same MariaDB with different users (app vs app_ro)
# to catch accidental writes through read sessions. Behind a DB proxy in cloud,
# point both at the proxy URL and set DB_PROBE_READ=false.
DB_WRITE_URL=mysql+asyncmy://app:app@localhost:3306/app
DB_READ_URL=mysql+asyncmy://app_ro:app_ro@localhost:3306/app
DB_SYNC_URL=mysql+pymysql://app:app@localhost:3306/app
DB_POOL_SIZE=5
# /readyz probes both engines locally. Set false behind a DB proxy (single endpoint).
DB_PROBE_READ=true

REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./uploads
STORAGE_LOCAL_BASE_URL=http://localhost:8000/static
# When STORAGE_BACKEND=gcs:
# GCS_BUCKET=your-bucket
# GCS_SIGNED_URLS=true          # required for private buckets
# GCS_URL_TTL_SECONDS=3600

# Prometheus /metrics endpoint — off locally, on in cloud.
ENABLE_METRICS=false

CORS_ORIGINS=http://localhost:5173
