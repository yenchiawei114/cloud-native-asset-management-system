APP_ENV=local
LOG_LEVEL=DEBUG
# text for local (human-readable), json in cloud (Cloud Logging auto-parses severity etc.)
LOG_FORMAT=text

SECRET_KEY="jwt-demo-secret-key-change-me"

# App uses asyncmy (async); Alembic uses pymysql (sync).
DB_URL=mysql+asyncmy://app:app@localhost:3306/app
DB_SYNC_URL=mysql+pymysql://app:app@localhost:3306/app
DB_POOL_SIZE=5

REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./uploads
STORAGE_LOCAL_BASE_URL=http://localhost:8000/static
# When STORAGE_BACKEND=gcs:
# GCS_BUCKET=your-bucket
# GCS_SIGNED_URLS=true          # required for private buckets
# GCS_URL_TTL_SECONDS=3600

# Prometheus /metrics endpoint — off locally, on in cloud.
ENABLE_METRICS=false

CORS_ORIGINS=http://localhost:5173

# --- Docker Compose ---
# MySQL container credentials
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app

# Container-to-container URLs (hostname = service name, not localhost)
COMPOSE_DB_URL=mysql+asyncmy://app:app@mysql:3306/app
COMPOSE_DB_SYNC_URL=mysql+pymysql://app:app@mysql:3306/app
COMPOSE_REDIS_URL=redis://redis:6379/0
COMPOSE_STORAGE_LOCAL_ROOT=/app/uploads
COMPOSE_STORAGE_LOCAL_BASE_URL=http://localhost:8000/static
COMPOSE_CORS_ORIGINS=http://localhost:5173,http://localhost
COMPOSE_API_BASE_URL=http://localhost:8000
WEB_CONCURRENCY=1
